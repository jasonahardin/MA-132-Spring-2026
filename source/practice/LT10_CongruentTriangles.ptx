<worksheet xml:id="practice-LT10-CongruentTriangles">
  <title>LT 10 Practice Problems</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
      LT 10: Determine whether two triangles are congruent, and use congruent triangles to solve problems.
    </p>
  </introduction>

  <exercise workspace="3in">
    <introduction>
      <p>
        Each figure below includes a pair of congruent triangles. Identify the triangles using an appropriate correspondence (e.g., <m>\triangle ABC \cong \triangle XYZ</m>) and state the reason that they are congruent (e.g., SSS, ASA, etc.).
      </p>
    </introduction>
