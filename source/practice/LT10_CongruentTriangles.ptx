<?xml version="1.0" encoding="UTF-8"?>

<!-- When creating a new activity, make a copy of this file with appropriate name -->
<worksheet xml:id="practice-LT10-CongruentTriangles">
  <title>LT 10 Practice Problems</title>

  <!-- Optional introduction -->
  <introduction>
    <p>
      LT 10: Determine whether two triangles are congruent, and use congruent triangles to solve problems.
    </p>
  </introduction>

  <exercise workspace="3in">
    <introduction>
      <p>
        Each figure below includes a pair of congruent triangles. Identify the triangles using an appropriate correspondence (e.g., <m>\triangle ABC \cong \triangle XYZ</m>) and state the reason that they are congruent (e.g., SSS, ASA, etc.).
      </p>
    </introduction>
    <task>
      <statement>
        <image source="CongruentTriangles1.png" width="50%">
        <shortdescription>Yes</shortdescription>
        </image>
      </statement>
      <answer>
        <p>
          <m>\triangle ABD \cong \triangle ACD</m> using SAS
        </p>
      </answer>
    </task>  
    <task>
      <statement>
        <image source="CongruentTriangles2.png" width="50%">
        <shortdescription>Yes</shortdescription>
        </image>
      </statement>
      <answer>
        <p>
          <m>\triangle EFG \cong \triangle EHG</m> using SSS
        </p>
      </answer>
    </task>
    <task>
      <statement>
        <image source="CongruentTriangles3.png" width="50%">
        <shortdescription>Yes</shortdescription>
        </image>
      </statement>
      <answer>
        <p>
          <m>\triangle IJK \cong \triangle KLI</m> using RHL
        </p>
      </answer>
    </task>
    <task>
      <statement>
        <image source="CongruentTriangles4.png" width="50%">
        <shortdescription>Yes</shortdescription>
        </image>
      </statement>
      <answer>
        <p>
          <m>\triangle MNO \cong \triangle QPO</m> using SAS
        </p>
      </answer>
    </task>
    <task>
      <statement>
        <image source="CongruentTriangles5.png" width="50%">
        <shortdescription>Yes</shortdescription>
        </image>
      </statement>
      <answer>
        <p>
          <m>\triangle RST \cong \triangle RUT</m> using RHL
        </p>
      </answer>
    </task>  
    <task>
      <statement>
        <image source="CongruentTriangles6.png" width="50%">
        <shortdescription>Yes</shortdescription>
        </image>
      </statement>
      <answer>
        <p>
          <m>\triangle XYZ \cong \triangle VZW</m> using SAS
        </p>
      </answer>
    </task>
  </exercise>



  <exercise workspace="3in">
    <statement>
      <p>
        In the figure below, <m>\triangle ABC \cong \triangle DCB</m>. Find the values of <m>x</m> and <m>y</m>.
      </p>
      <image source="SolveCongruentTriangles1.png" width="50%">
        <shortdescription>Yes</shortdescription>
        </image>
    </statement>
    <answer>
      <p>
        <m>x = 6</m> and <m>y = 9</m>
      </p>
    </answer>
  </exercise>

  

  <exercise workspace="3in">
    <statement>
      <p>
        In the figure below, <m>\triangle RST \cong \triangle VUT</m>. Find the values of <m>a</m> and <m>b</m>.
      </p>
      <image source="SolveCongruentTriangles2.png" width="50%">
        <shortdescription>Yes</shortdescription>
        </image>
    </statement>
    <answer>
      <p>
        <m>a = 40</m> and <m>b = 5.8</m> cm
      </p>
    </answer>
  </exercise>

</worksheet>
